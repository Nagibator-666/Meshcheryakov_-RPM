class ConsoleMarket:
    def init(self, make, model, year, price):
        self.make = make
        self.model = model
        self.year = year
        self.price = price
        
        
    def info(self):
        print(f"Марка:" {self.make}
            f"\n Модель: {self.model}"
            f"\n Год выпуска {self.year}"
            f"\n Цена {self.price} руб")
            
            
class Console(ConsoleMarket):
    def init(self, make, model, year, price, number):
        super().init(make, model, year, price)
        self.number = number
        
        
console = Console("Sony", "ps3", 2012, 8000)

console.info()
