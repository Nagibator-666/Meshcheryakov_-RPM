using System;

             
class Animal
{
    string species;
    int age;

    public Animal(string species)
    {
        this.species = species;
        Console.WriteLine("Animal(string species)");
    }

    public Animal(string species, int age) : this(species)
    {
        this.age = age;
        Console.WriteLine("Animal(string species, int age)");
    }
    public void ShowInfo()
    {
        Console.WriteLine($"Вид: {species}, Возраст: {age}");
    }
}



class Dog:Animal
{
    string breed;

    public Dog(string species, int age, string breed) : base(species, age)
    {
        this.breed = breed;
        Console.WriteLine("Dog(string species, int age, string breed)");
    }

    public void Bark()
    {
        Console.WriteLine($"{breed} говорит: ГАВ-ГАВ!");
    }
}




class Program
{
    static void Main()
    {
        Dog myDog = new Dog("Canine", 3, "Labrador");

        myDog.ShowInfo();
        myDog.Bark();
    }
    
}





